# ── App ──
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ── Database ──
DATABASE_URL=postgresql://user:password@localhost:5432/learnai

# ── Auth (Clerk) ──
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── AI Service ──
AI_SERVICE_URL=http://localhost:8000
INTERNAL_SERVICE_SECRET=change-me-to-a-random-64-char-string

# ── Redis ──
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_AI_TOKENS_PRICE_ID=price_your_price_id
STRIPE_SEATS_PRICE_ID=price_your_seats_price_id

# ── Email (SendGrid) ──
SENDGRID_API_KEY=SG.your_sendgrid_key
EMAIL_FROM=noreply@yourdomain.com

# ── BullMQ / Redis ──
BULLMQ_REDIS_URL=redis://localhost:6379

# ── JWT ──
JWT_SECRET=change-me-to-a-random-64-char-string

# ── Monitoring ──
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project
POSTHOG_KEY=phc_your_posthog_key
