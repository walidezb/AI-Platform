# ══════════════════════════════════════
# NestJS API — Environment Variables
# ══════════════════════════════════════

NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/learnai?sslmode=disable
DIRECT_URL=postgresql://user:password@localhost:5432/learnai?sslmode=disable

REDIS_URL=redis://localhost:6379
REDIS_TLS=false

CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

AI_SERVICE_URL=http://localhost:8001
INTERNAL_SERVICE_SECRET=                # 64-char random string

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_AI_TOKENS_PRICE_ID=price_...
STRIPE_SEATS_PRICE_ID=price_...

SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@yourdomain.com

JWT_SECRET=                             # 64-char random string
SENTRY_DSN=https://...@sentry.io/...
APP_URL=http://localhost:3000

TEST_SEED_SECRET=test-seed-secret-for-e2e

POSTHOG_API_KEY=phc_...                    # Server-side PostHog API key
POSTHOG_HOST=https://app.posthog.com

