# ══════════════════════════════════════
# Python AI Service — Environment Variables
# ══════════════════════════════════════

PYTHON_ENV=development
PORT=8000

OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=learnai-development
PINECONE_ENVIRONMENT=...

DATABASE_URL=postgresql://user:password@localhost:5432/learnai?sslmode=disable
REDIS_URL=redis://localhost:6379
INTERNAL_SERVICE_SECRET=                # Same 64-char secret as NestJS API

GOOGLE_SEARCH_API_KEY=...
GOOGLE_SEARCH_ENGINE_ID=...

# LangSmith Tracing (optional)
LANGSMITH_API_KEY=                      # Optional: LangSmith API key for tracing
LANGCHAIN_PROJECT=learnai-production
