# ══════════════════════════════════════
# AI Learning Platform — Environment Variables
# Copy to .env.local (web) and .env (api/ai)
# NEVER commit real values to git
# ══════════════════════════════════════

# ── Database ──
DATABASE_URL=postgresql://user:password@host/learnai?sslmode=require
DIRECT_URL=postgresql://user:password@host/learnai?sslmode=require

# ── Redis ──
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ── Clerk Auth ──
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── AI Service ──
OPENAI_API_KEY=sk-...
AI_SERVICE_URL=http://localhost:8001
INTERNAL_SERVICE_SECRET=                # 64-char random: node -e "require('crypto').randomBytes(64).toString('hex')"

# ── Vector DB (Pinecone) ──
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=learnai-development
PINECONE_ENVIRONMENT=...

# ── Web Search (Resource Curation) ──
GOOGLE_SEARCH_API_KEY=...
GOOGLE_SEARCH_ENGINE_ID=...

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_AI_TOKENS_PRICE_ID=price_...
STRIPE_SEATS_PRICE_ID=price_...

# ── Email (SendGrid) ──
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@yourdomain.com

# ── Security ──
JWT_SECRET=                             # 64-char random (different from INTERNAL_SERVICE_SECRET)

# ── URLs ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
APP_URL=http://localhost:3000

# ── Monitoring ──
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Testing (E2E — never use in production) ──
TEST_URL=http://localhost:3000
TEST_API_URL=http://localhost:3001
TEST_SEED_SECRET=                       # Any string for local E2E tests
TEST_MANAGER_EMAIL=test-manager@learnai.com
TEST_MANAGER_PASSWORD=TestPassword123!
TEST_LEARNER_EMAIL=test-learner@learnai.com
TEST_LEARNER_PASSWORD=TestPassword123!
